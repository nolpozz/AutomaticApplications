# Python
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
build/
dist/
.venv/
venv/
.mypy_cache/
.ruff_cache/
.pytest_cache/
.coverage
htmlcov/

# Environment / secrets
.env

# Per-user configuration. Each user's personal tailoring (targeting, locations,
# blocklist, thresholds, prestige boost) lives here and must NOT be committed —
# that would change the defaults for every other user. The shared, committed
# defaults live in config/config.example.yaml and config/sources.yaml.
/config/config.yaml

# Personal background — NEVER pushed. Your real resume content lives here.
# The committed `user_data.example/` is the template to copy from.
/user_data/*
!/user_data/.gitkeep

# Runtime data (SQLite, FAISS, generated documents/resumes/cover letters, Excel).
# All generated artifacts contain personal info and stay local.
/data/
!/data/.gitkeep

# OS
.DS_Store
