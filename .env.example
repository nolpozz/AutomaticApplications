# ---------------------------------------------------------------------------
# Job Agent configuration. Copy to `.env` and fill in what you need.
# Every value here can also be supplied via config/config.yaml or defaults.
# Environment variables take precedence over YAML, which takes precedence
# over built-in defaults. All variables are prefixed with JOB_AGENT_.
# ---------------------------------------------------------------------------

# --- LLM provider selection -------------------------------------------------
# One of: openai | anthropic | gemini | ollama | vllm | mock
# Default is OpenAI. Use `mock` (no key needed) to try the pipeline offline.
JOB_AGENT_LLM__PROVIDER=openai
JOB_AGENT_LLM__MODEL=gpt-4o
JOB_AGENT_LLM__TEMPERATURE=0.2
# Optional per-stage model overrides. A cheap model for the high-volume stages
# keeps cost down while the strong MODEL above writes the documents.
# JOB_AGENT_LLM__PARSE_MODEL=gpt-4o-mini
# JOB_AGENT_LLM__CLASSIFY_MODEL=gpt-4o-mini
# JOB_AGENT_LLM__RESUME_MODEL=gpt-4o
# JOB_AGENT_LLM__COVER_LETTER_MODEL=gpt-4o
JOB_AGENT_LLM__MAX_TOKENS=4096
JOB_AGENT_LLM__MAX_RETRIES=3
JOB_AGENT_LLM__TIMEOUT_SECONDS=60

# --- Provider API keys (only the selected provider is required) -------------
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
# Base URLs for self-hosted providers
JOB_AGENT_LLM__OLLAMA_BASE_URL=http://localhost:11434
JOB_AGENT_LLM__VLLM_BASE_URL=http://localhost:8000/v1

# --- Embeddings -------------------------------------------------------------
# provider: sentence-transformers | mock
JOB_AGENT_EMBEDDING__PROVIDER=mock
JOB_AGENT_EMBEDDING__MODEL=sentence-transformers/all-MiniLM-L6-v2
JOB_AGENT_EMBEDDING__DIMENSION=384

# --- Storage paths ----------------------------------------------------------
JOB_AGENT_STORAGE__SQLITE_PATH=./data/job_agent.db
JOB_AGENT_STORAGE__FAISS_PATH=./data/faiss
JOB_AGENT_STORAGE__EXCEL_PATH=./data/job_agent.xlsx
JOB_AGENT_STORAGE__CHECKPOINT_PATH=./data/checkpoints.sqlite
JOB_AGENT_STORAGE__DOCUMENTS_PATH=./data/documents

# --- Pipeline behavior ------------------------------------------------------
JOB_AGENT_PIPELINE__MAX_JOBS=50
# After cheap embed + relevance ranking, only the top-N most-relevant roles per
# company go to the expensive LLM stages. Set 0 to disable the per-company cap.
JOB_AGENT_PIPELINE__TOP_PER_COMPANY=5
JOB_AGENT_PIPELINE__CLASSIFIER_THRESHOLD=0.65
JOB_AGENT_PIPELINE__MAX_APPLICATIONS_PER_DAY=20
JOB_AGENT_PIPELINE__ENABLED_BOARDS=greenhouse,lever,ashby,yc
JOB_AGENT_PIPELINE__AUTO_SYNC_EXCEL=true

# Which roles to search for across search-based boards (amazon, netflix, google).
# The built-in default already covers ML / AI research + engineering titles;
# set this only to change scope. Comma-separated.
# JOB_AGENT_PIPELINE__SEARCH_QUERIES=machine learning engineer,ai research,research scientist,applied scientist,nlp engineer,computer vision,machine learning intern

# --- Ranking & targeting (all optional, all default off) --------------------
# These reshape which roles reach the expensive stages and how they rank. They
# are deterministic and also honored by scripts/rescore.py, so you can tune them
# and re-rank an existing database with no LLM calls. See docs/setup.md.

# Role targeting: prefer roles matching these levels/keywords; off-target roles
# are multiplied down. Example — Master's-level internships:
# JOB_AGENT_PIPELINE__TARGET_EXPERIENCE_LEVELS=intern
# JOB_AGENT_PIPELINE__TARGET_KEYWORDS=intern,internship,summer,co-op,graduate
# JOB_AGENT_PIPELINE__TARGET_DESCRIPTION=Master's-level internships

# Domain gate: a role with NONE of these terms in its title/description/skills is
# multiplied by DOMAIN_PENALTY (push generic roles below threshold). >=1.0 = off.
# JOB_AGENT_PIPELINE__DOMAIN_KEYWORDS=ml,ai,machine learning,nlp,llm,deep learning
# JOB_AGENT_PIPELINE__DOMAIN_PENALTY=0.5

# Company prestige: FAANG+/top-AI-labs get +PRESTIGE_BOOST (high-growth gets 0.6x),
# and prestigious companies keep TOP_PER_COMPANY * PRESTIGE_CAP_MULTIPLIER roles.
# JOB_AGENT_PIPELINE__PRESTIGE_BOOST=0.05
# JOB_AGENT_PIPELINE__PRESTIGE_CAP_MULTIPLIER=2
# JOB_AGENT_PIPELINE__PRESTIGE_EXTRA_FAANG=
# JOB_AGENT_PIPELINE__PRESTIGE_EXTRA_GROWTH=

# Additive boosts (capped by BOOST_CAP) for preferred locations / title terms.
# Geography has NO effect unless you set these; even then it only nudges ranking.
# JOB_AGENT_PIPELINE__TARGET_LOCATIONS=new york,nyc,remote
# JOB_AGENT_PIPELINE__LOCATION_BOOST=0.05
# JOB_AGENT_PIPELINE__BOOST_KEYWORDS=research,nlp,computer vision
# JOB_AGENT_PIPELINE__KEYWORD_BOOST=0.03
# JOB_AGENT_PIPELINE__BOOST_CAP=0.1

# Never surface these employers (dropped at scrape time, before any LLM spend).
# JOB_AGENT_PIPELINE__BLOCKED_COMPANIES=

# --- Observability ----------------------------------------------------------
JOB_AGENT_LOG_LEVEL=INFO
